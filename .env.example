# Template for required environment variables. Copy to `.env.local`
# (which is gitignored) and fill in real values. `.env.example` is safe
# to commit.

# --- Site ---
# Absolute origin for sitemap, robots, OG metadata, hreflang.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Database (Supabase Postgres) ---
# Connection string Supabase shows under Connect → ORM → Drizzle.
# Pooled (port 6543) — used by the app at runtime, works in Vercel
# serverless. The `?pgbouncer=true` flag matters.
DATABASE_URL="postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct (port 5432) — used by Drizzle Kit for migrations.
DIRECT_URL="postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Auth.js ---
# Output of `openssl rand -base64 32`. Required in production.
AUTH_SECRET=""
# `true` when not on Vercel (e.g. local dev, custom self-host).
AUTH_TRUST_HOST="true"

# --- Telegram (Login Widget) ---
# From @BotFather: /newbot → token at the end of the reply.
TELEGRAM_BOT_TOKEN=""
# Bot username (ends in `bot`), without the @.
TELEGRAM_BOT_USERNAME=""
